# --- System Files ---
.DS_Store
Thumbs.db

# --- Dependency Folders ---
# This covers node_modules in both Frontend and Backend
**/node_modules/

# --- Next.js Build Output ---
# This ignores the hidden build folder inside Frontend
Frontend/.next/
Frontend/out/
Frontend/build/
**/.next/

# --- Backend Build/Logs ---
Backend/dist/
Backend/build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Environment Secrets (CRITICAL) ---
# Never upload these! They contain your API keys and DB passwords.
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
**/.env
**/.env.local

# --- IDEs and Tools ---
.vscode/
.idea/
.env.bak
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
